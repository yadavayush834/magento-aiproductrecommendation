<?php
/** @var \Custom\AiProductRecommendation\Block\Product\Recommendations $block */
$products = $block->getRecommendedProducts();
?>

<?php if ($block->isEnabled() && !empty($products)): ?>
<div class="ai-recommendations-wrapper">
    <h3 class="ai-recommendations-title">
        <?= __('You May Also Like') ?>
    </h3>

    <div class="ai-recommendations-grid">
        <?php foreach ($products as $product): ?>
        <div class="ai-recommendation-item">

            <!-- Product Image -->
            <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>"
               class="ai-rec-image-link">
                <img src="<?= $block->escapeUrl($block->getImage($product, 'product_thumbnail_image')->getImageUrl()) ?>"
                     alt="<?= $block->escapeHtmlAttr($product->getName()) ?>"
                     class="ai-rec-image"
                     loading="lazy"/>
            </a>

            <!-- Product Name -->
            <a href="<?= $block->escapeUrl($product->getProductUrl()) ?>"
               class="ai-rec-name">
                <?= $block->escapeHtml($product->getName()) ?>
            </a>

            <!-- Price -->
            <div class="ai-rec-price">
                <?= $block->getProductPrice($product) ?>
            </div>

            <!-- Add to Cart -->
            <button class="action tocart ai-rec-cart-btn"
                    data-product-id="<?= (int)$product->getId() ?>"
                    onclick="window.location.href='<?= $block->escapeUrl($product->getProductUrl()) ?>'">
                <?= __('View Product') ?>
            </button>

        </div>
        <?php endforeach; ?>
    </div>
</div>

